# Kopiere diese Datei zu ".env" und trage deine Werte ein.
# Die .env-Datei NIE committen (steht in .gitignore).
ANTHROPIC_API_KEY=sk-ant-dein-schluessel-hier

# Supabase. Werte aus Supabase -> Project Settings -> API.
# anon-Key ist öffentlich (KEIN Geheimnis); der SERVICE-Key ist GEHEIM wie ein
# Passwort — nur hier / als Netlify-Env, NIEMALS ins Frontend oder nach Git!
# Der Server (Functions) braucht den Service-Key, um firmen/scan_jobs zu lesen,
# seit RLS den anonymen Zugriff sperrt (siehe migration-m0.sql).
SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
SUPABASE_ANON_KEY=dein-anon-oder-publishable-key
SUPABASE_SERVICE_KEY=dein-service-role-key
